{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "ROS2: C++ Hardware Node",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/install/charge_port/lib/charge_port/hardware_node",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "PYTHONPATH",
                    "value": "/opt/ros/humble/lib/python3.10/site-packages:${workspaceFolder}/install/charge_port/lib/python3.10/site-packages"
                },
                {
                    "name": "LD_LIBRARY_PATH",
                    "value": "/opt/ros/humble/opt/rviz_ogre_vendor/lib:/opt/ros/humble/lib/x86_64-linux-gnu:/opt/ros/humble/lib:${workspaceFolder}/install/charge_port/lib"
                },
                {
                    "name": "AMENT_PREFIX_PATH",
                    "value": "/opt/ros/humble:${workspaceFolder}/install/charge_port"
                }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "ROS2: Python Detection Node",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/install/charge_port/lib/charge_port/detection_node.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/install/charge_port/lib/python3.10/site-packages:${env:PYTHONPATH}"
            }
        }
    ]
}